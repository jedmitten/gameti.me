# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_64_char_hex_string
SITE_ADMIN_SECRET=replace_with_strong_password

DB_PATH=data/ourtime.db
BASE_URL=http://localhost:8000
EVENT_EXPIRY_DAYS=90

# Leave empty to disable email (recovery tokens printed to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@localhost
SMTP_TLS=true
